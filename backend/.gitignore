# --- Данные приложения и локальные БД ---
# Игнорируем локальную SQLite базу данных telemetry.db
*.db
*.sqlite3

# --- Окружение и конфигурация ---
# Локальные переменные окружения (токены бота, настройки портов)
.env
.env.local
.env.*.local

# --- Python-специфичные файлы ---
# Байт-код (компилированные файлы Python)
__pycache__/
*.py[cod]
*$py.class

# Виртуальное окружение (папки, куда ставятся pip-пакеты)
venv/
.venv/
env/
ENV/
dist/
build/
*.egg-info/

# --- Настройки IDE и редакторов ---
# JetBrains (PyCharm / WebStorm)
.idea/

# VS Code
.vscode/
*.code-workspace

# Логи
*.log
logs/

# Системные файлы
.DS_Store
Thumbs.db